{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Stores user settings and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "customApiKey": { "type": "string", "description": "User provided Gemini API Key" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "userProfile",
      "description": "User specific data"
    }
  }
}
